t_cloud_public_region      = "eu-de"
t_cloud_public_domain_name = ""
t_cloud_public_tenant_name = "{{ .cluster.terraform.projectId }}"
t_cloud_public_access_key  = ""
t_cloud_public_secret_key  = ""

bucket_name = "bucket-tf-{{ .cluster.name }}-{{ .cluster.stage }}"
user_name   = "tfstate-{{ .cluster.name }}-{{ .cluster.stage }}"

enable_bucket_server_side_encryption = true
bucket_kms_pending_days              = 7
