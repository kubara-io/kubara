traefik:
  deployment:
    imagePullSecrets:
      - name: image-pull-secret
  metrics:
    prometheus:
      serviceMonitor:
        enabled: {{ eq .cluster.services.kubePrometheusStack.status "enabled" }}
        additionalLabels:
          monitoring.instance: "{{ .cluster.name }}-{{ .cluster.stage }}"

namespace:
  labels:
    project-name: "{{ .cluster.name }}"
    stage: "{{ .cluster.stage }}"
