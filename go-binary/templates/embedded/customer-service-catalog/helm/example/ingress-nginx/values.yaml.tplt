ingress-nginx:
  imagePullSecrets:
    - name: image-pull-secret
  controller:
    metrics:
      serviceMonitor:
        {{- if (eq .cluster.services.kubePrometheusStack.status "enabled") }}
        enabled: true
        {{- end }}
        additionalLabels:
          monitoring.instance: "{{ .cluster.name }}-{{ .cluster.stage }}"
  defaultBackend:
    enabled: false
namespace:
  labels:
    project-name: "{{ .cluster.name }}"
    stage: "{{ .cluster.stage }}"
